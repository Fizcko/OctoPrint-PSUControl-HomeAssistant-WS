<!-- ko ifnot: settings.plugins.psucontrol -->
<span class="help-inline label label-important">This plugin requires <a href="https://plugins.octoprint.org/plugins/psucontrol/" target="_blank">PSU Control</a> in order to function. It can be installed from the Plugin Manager.</span>
<!-- /ko -->
<!-- ko if: settings.plugins.psucontrol && !(settings.plugins.psucontrol.switchingMethod() === "PLUGIN" && settings.plugins.psucontrol.switchingPlugin() === "psucontrol_hass_ws") -->
    <span class="help-inline label label-important">Please set the switching method to <b>PLUGIN</b> and the switching plugin to <b>PSU Control - HomeAssistant</b> in the PSU Control settings to use this plugin.</span>
<!-- /ko -->
<!-- ko if: settings.plugins.psucontrol && !(settings.plugins.psucontrol.sensingMethod() === "PLUGIN" && settings.plugins.psucontrol.sensingPlugin() === "psucontrol_hass_ws") -->
    <span class="help-block label label-important">Please set the sensing method to <b>PLUGIN</b> and the sensing plugin to <b>PSU Control - HomeAssistant</b> in the PSU Control settings to use this plugin.</span>
<!-- /ko -->
<!-- ko ifnot: settings.plugins.psucontrol.autoOn() -->
<form class="form-horizontal">
    <h4>PSU Control - HomeAssistant settings</h4>
    <div class="control-group">
        <label class="control-label">Address</label>
        <div class="controls">
            <input type="text" class="input" data-bind="value: settings.plugins.psucontrol_hass_ws.address">
            <span class="help-block">The IP address or hostname of your HomeAssistant server. e.g. http://ip:port or http://hostname:port. Do not include a trailing slash /</span>
        </div>
    </div>
    <div class="control-group">
        <label class="control-label">Access token</label>
        <div class="controls">
            <input type="text" class="input" data-bind="value: settings.plugins.psucontrol_hass_ws.api_key">
            <span class="help-block">The long-lived access token generated by HomeAssistant. See <a href="https://github.com/fizcko/OctoPrint-PSUControl-HomeAssistant-WS#configuration" target="_blank">plugin configuration</a> for more info.</span>
        </div>
    </div>
    <div class="control-group">
        <label class="control-label">Entity ID</label>
        <div class="controls">
            <input type="text" class="input" data-bind="value: settings.plugins.psucontrol_hass_ws.entity_id">
            <span class="help-block">The ID of the entity you'd like to control. Can be anything supporting the turn_on/turn_off services, but a switch would make the most sense.</span>
        </div>
    </div>
    <div class="control-group">
        <div class="controls">
            <label class="checkbox">
            <input type="checkbox" data-bind="checked: settings.plugins.psucontrol_hass_ws.use_websocket"> Use WebSocket
            </label>
            <span class="help-block">Subscribe to Home Assistant state changes over WebSocket. State is pushed by HA, eliminating polling. Falls back to REST if the WebSocket is unavailable.</span>
        </div>
    </div>
    <div class="control-group">
        <label class="control-label">Fallback poll interval</label>
        <div class="controls">
            <input type="number" min="0" class="input" data-bind="value: settings.plugins.psucontrol_hass_ws.fallback_poll_interval">
            <span class="help-block">Minimum seconds between REST state queries when the WebSocket is disconnected. Prevents hammering HA on sustained outages.</span>
        </div>
    </div>
    <div class="control-group">
        <label class="control-label">Custom headers</label>
        <div class="controls">
            <table class="table table-condensed">
                <thead><tr><th>Name</th><th>Value</th><th></th></tr></thead>
                <tbody data-bind="foreach: settings.plugins.psucontrol_hass_ws.custom_headers">
                    <tr>
                        <td><input type="text" class="input-small" data-bind="value: name"></td>
                        <td><input type="text" class="input-medium" data-bind="value: value"></td>
                        <td><button type="button" class="btn btn-small" data-bind="click: function() { $parent.settings.plugins.psucontrol_hass_ws.custom_headers.remove($data); }">Remove</button></td>
                    </tr>
                </tbody>
            </table>
            <button type="button" class="btn btn-small" data-bind="click: function() { settings.plugins.psucontrol_hass_ws.custom_headers.push({ name: ko.observable(''), value: ko.observable('') }); }">Add header</button>
            <span class="help-block">Sent with every HTTP request and WebSocket upgrade (e.g. for Cloudflare Access, reverse-proxy auth). Authorization is managed automatically.</span>
        </div>
    </div>
    <div class="control-group">
        <div class="controls">
            <label class="checkbox">
            <input type="checkbox" data-bind="checked: settings.plugins.psucontrol_hass_ws.verify_certificate"> Verify certificate
            </label>
            <!-- ko if: settings.plugins.psucontrol_hass_ws.verify_certificate -->
            <span class="help-block">Verify TLS certificate and do not connect on certificate issues.</span>
            <!-- /ko -->
            <!-- ko ifnot: settings.plugins.psucontrol_hass_ws.verify_certificate -->
            <span class="help-block">Do not verify TLS certificate.</span>
            <!-- /ko -->
        </div>
    </div>
    <div class="control-group">
        <label class="control-label">Diagnostics</label>
        <div class="controls">
            <button type="button" class="btn" id="psucontrol_hass_ws_test_btn">Test connection</button>
            <span class="help-block">Runs REST reachability, entity lookup and WebSocket auth/subscribe using the <b>saved</b> settings. Click <i>Save</i> first if you changed any field above.</span>
            <div id="psucontrol_hass_ws_test_result" style="margin-top: 8px;"></div>
        </div>
    </div>
</form>
<!-- /ko -->
<!-- ko if: settings.plugins.psucontrol.autoOn() -->
<span class="help-inline label label-important">Please DISABLE <u>Automatically turn PSU ON</u> in the PSU Control settings, it will otherwise ruin your prints when HA becomes unavailable.<br>
See <a href="https://github.com/fizcko/OctoPrint-PSUControl-HomeAssistant-WS#setup" target="_blank">setup</a> for more info.</span>
<!-- /ko -->
